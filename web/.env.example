# Backend API + Socket.IO server
VITE_API_URL=http://localhost:4000

# From Google Cloud Console > APIs & Services > Credentials.
# A single Web application OAuth Client ID works for both this app and the
# server's GOOGLE_CLIENT_ID (they must match -- the server verifies the
# token's audience against it). Add this app's origin (e.g.
# http://localhost:5173, and your LAN IP/deployed domain) to
# "Authorized JavaScript origins" on that credential.
VITE_GOOGLE_CLIENT_ID=
